# SurrealDB settings
SURREAL_URL="ws://127.0.0.1:8000/rpc"
SURREAL_NAMESPACE="main"
SURREAL_DATABASE="main"
SURREAL_ROOT="root"
SURREAL_ROOT_PASSWORD="change-me"

# Nuxt session encryption password, 32+ characters recommended
NUXT_SESSION_PASSWORD="replace-with-a-long-random-session-secret"

# App Auth
APP_LOGIN_USERNAME="admin"
APP_LOGIN_PASSWORD="change-me"

# Backward-compatible aliases supported by the app, but APP_LOGIN_* avoids OS env collisions.
USERNAME="admin"
PASSWORD="change-me"