# Initialization settings for the app
# APP_ENV: "dev" = local Windows dev (Surreal is remote), "prod" = same-server Ubuntu deployment
APP_ENV="dev"

# SurrealDB settings
SURREAL_URL="wss://surreal.example.com/rpc"
SURREAL_NAMESPACE="main"
SURREAL_DATABASE="main"
SURREAL_ROOT="root"
SURREAL_ROOT_PASSWORD="change-me"

# Nuxt session encryption password (MUST be 32+ random characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_SESSION_PASSWORD="change-me-to-32-plus-random-chars"

# App Auth — admin login
APP_LOGIN_USERNAME="admin"
# Generate hash with: npm run hash-password "your-password"
APP_LOGIN_PASSWORD_HASH=""

# Optional public-site fallbacks. Admin Settings overrides these at runtime.
APP_SITE_TITLE="PandaBlog"
APP_SITE_SUBTITLE=""
APP_SITE_LOGO=""
APP_SITE_BANNER=""
APP_SITE_FAVICON="/favicon.ico"
APP_OWNER_NAME=""
APP_OWNER_BIO=""
APP_OWNER_AVATAR=""